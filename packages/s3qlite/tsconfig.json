{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"types": ["vitest", "vitest/globals", "bun-types"]
	},
	"include": ["src/**/*", "tests/**/*", "examples/**/*"],
	"exclude": ["node_modules"]
}