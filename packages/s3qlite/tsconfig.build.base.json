{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": ".",
		"target": "ES2022",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": false,
		"noEmit": false,
		"declaration": false,
		"declarationMap": false,
		"sourceMap": true,
		"inlineSources": true,
		"removeComments": false,
		"types": ["bun-types"]
	},
	"include": ["index.ts", "effect.ts", "src/**/*.ts"],
	"exclude": ["node_modules", "tests", "coverage", "dist", "**/*.test.ts", "vitest.config.ts"]
}
