{
	"name": "@lika85456/s3qlite",
	"version": "0.2.1",
	"license": "MIT",
	"repository": "github:lika85456/s3qlite",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/dts/index.d.ts",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/dts/index.d.ts",
			"import": "./dist/esm/index.js",
			"default": "./dist/cjs/index.js"
		},
		"./effect": {
			"types": "./dist/dts/effect.d.ts",
			"import": "./dist/esm/effect.js",
			"default": "./dist/cjs/effect.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist",
		"linkDirectory": false
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.esm.json && tsc -p tsconfig.build.cjs.json && tsc -p tsconfig.build.dts.json && bun scripts/prepare-dist.ts",
		"lint": "oxlint .",
		"format": "oxfmt .",
		"test": "vitest",
		"test:ci": "vitest run --coverage --silent",
		"test:integration": "vitest --project integration",
		"test:fuzzy": "vitest --project fuzzy",
		"check-types": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect-aws/client-s3": "^1.11.0",
		"@effect/platform": "^0.96.0",
		"@effect/platform-bun": "^0.89.0",
		"@effect/platform-node": "^0.106.0",
		"@tursodatabase/database": "^0.6.0",
		"effect": "^3.21.2",
		"protobufjs": "^8.4.2",
		"uuid": "^14.0.0"
	},
	"devDependencies": {
		"@effect/vitest": "^0.29.0",
		"bun-types": "^1.3.9",
		"drizzle-orm": "^1.0.0-beta.22",
		"fast-check": "^4.8.0"
	},
	"peerDependencies": {
		"zod": "^4.0.0"
	}
}
